NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3054
MCRAFTR_ADMIN_USER=admin@example.com
MCRAFTR_ADMIN_PASS=replace-me
MCRAFTR_ENC_KEY=replace-me
REDIS_PASSWORD=replace-me
REDIS_URL=redis://:replace-me@mcraftr-redis:6379
DATA_DIR=/app/data
ALLOW_REGISTRATION=false
MCRAFTR_BIND_HOST=127.0.0.1
MCRAFTR_BIND_PORT=3054
MCRAFTR_ALLOW_PRIVATE_RCON_HOSTS=false
MCRAFTR_DISABLE_RATE_LIMITING=false

# MCRAFTR_BIND_HOST examples:
# - 127.0.0.1 for this machine only
# - 100.x.x.x or server.tailnet.ts.net for private-network access
# - 0.0.0.0 for local-network access

# Optional public HTTPS install helpers
# SITE_DOMAIN=mcraftr.example.com
# LETSENCRYPT_EMAIL=you@example.com

# Optional image/compose install helpers
# MCRAFTR_IMAGE=ghcr.io/deployfaith/mcraftr:latest

# Optional Full Mcraftr Stack / Beacon values
# MCRAFTR_BEACON_TOKEN=replace-me
# MCRAFTR_MINECRAFT_DATA=/srv/minecraft/data
# MCRAFTR_SCHEMATICS_DIR=plugins/WorldEdit/schematics
# MCRAFTR_ENTITY_PRESET_DIR=mcraftr/entity-presets
# MCRAFTR_BLUEMAP_URL=https://map.example.com
# MCRAFTR_DYNMAP_URL=https://dynmap.example.com

# Optional: disable API rate limiting entirely (not recommended)
# MCRAFTR_DISABLE_RATE_LIMITING=true
