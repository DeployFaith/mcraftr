{
  "name": "mcraftr",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "setup:env": "node scripts/setup-env.mjs",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "node server.js",
    "lint": "eslint .",
    "beacon": "node beacon/server.mjs",
    "dokploy:deploy": "node scripts/dokploy-deploy.mjs",
    "catalog:art:audit": "npx -y tsx scripts/audit-catalog-art.ts",
    "catalog:art:entity-plan": "npx -y tsx scripts/audit-entity-art.ts",
    "pw:install": "playwright install chromium",
    "pw:entity-audit": "playwright test tests/playwright/entity-art.spec.ts --project=desktop-chromium",
    "pw:screenshots": "playwright test tests/playwright/repo-screenshots.spec.ts --project=desktop-chromium",
    "pw:screenshots:live-sections": "node scripts/capture-live-sections.mjs",
    "pw:screenshots:highlights": "node scripts/capture-repo-highlights.mjs",
    "pw:screenshots:long-sections": "node scripts/capture-long-pages-sections.mjs",
    "pw:audit": "playwright test",
    "pw:audit:headed": "playwright test --headed"
  },
  "dependencies": {
    "@radix-ui/react-switch": "^1.2.6",
    "@types/ioredis": "^4.28.10",
    "@uiw/react-color": "^2.9.6",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "ioredis": "^5.9.3",
    "lucide-react": "^0.575.0",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.25",
    "pngjs": "^7.0.0",
    "prismarine-nbt": "^2.8.0",
    "rate-limiter-flexible": "^9.1.1",
    "rcon-client": "^4.2.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/adm-zip": "^0.5.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
